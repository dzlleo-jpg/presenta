{
  "$schema_version": "dna-tokens-v0.4-template",
  "_template_meta": {
    "purpose": "Skeleton for new DNA tokens.json files generated by dna-forge skill.",
    "instructions": [
      "Replace {PLACEHOLDERS} with concrete values determined in Phases 1-7 of dna-forge methodology",
      "Delete sections that don't apply (eg cjk_typography if Latin-only)",
      "Keep ALL v0.3 mandatory sections: pre_check_protocol, layout_safety, signatures (even if minimal)",
      "Keep ALL v0.4 mandatory sections: font_selection, modern_css, ai_slop_anti_patterns, variance_dial, ppt_keynote.slide_vs_speaker_notes_rules",
      "After v0.1 is generated, run playtest (Phase 8) and produce v0.2/v0.3/v0.4 with hardened rules"
    ],
    "delete_this_template_meta_block_in_actual_output": true
  },

  "name": "{DNA_NAME_LOWERCASE_SLUG}",
  "version": "0.1.0",
  "description": "{ONE_SENTENCE_DNA_DESCRIPTION_FUSING_REFERENCES}",

  "_notes": {
    "v0_1_authored_during": "{PROJECT_CONTEXT}",
    "playtest_status": "not_yet_playtested_in_v0_1"
  },

  "universal_floor": {
    "min_font_size_px": 11,
    "min_font_size_px_ppt_projection": 14,
    "min_contrast_ratio": 4.5,
    "min_touch_target_pt": 24,
    "max_line_chars_latin": 75,
    "max_line_chars_cjk": 25,
    "min_whitespace_ratio_main": 0.4,
    "min_type_scale_ratio": 1.25,
    "min_visual_hierarchy_levels": 3,
    "max_concurrent_weights": 2,
    "max_concurrent_font_sizes_per_screen": 5,
    "max_alignment_columns": 3,
    "min_line_height_hero_latin": 0.9,
    "min_line_height_hero_cjk": 1.05,
    "min_line_height_body_latin": 1.5,
    "min_line_height_body_cjk": 1.7,
    "min_line_height_caption": 1.4
  },

  "pre_check_protocol": {
    "_critical": "v0.3 mandatory section. Every DNA must include this. Without it, spec rules don't auto-trigger.",
    "trigger": "before_generating_any_artifact",
    "steps": [
      {
        "step": 1,
        "name": "select_subsystem_spectrum_signature",
        "actions": [
          "choose subsystem from available list",
          "choose layered modifier (optional)",
          "decide if signature applies (default no; if yes, choose 1)"
        ]
      },
      {
        "step": 2,
        "name": "compute_text_bandwidth",
        "actions": [
          "available_width = container_width × 0.92",
          "estimate hero max chars per line using char_width_estimates_px",
          "if hero content exceeds max chars: force wrap or reduce hero size 1 step"
        ]
      },
      {
        "step": 3,
        "name": "vertical_height_estimation",
        "actions": [
          "sum all element heights + paddings + gaps",
          "if sum > container_height - 16px safety: invoke fallback_order"
        ]
      },
      {
        "step": 4,
        "name": "anti_pattern_scan",
        "actions": [
          "iterate through all drift_violations in section 6.2",
          "any yes flag → modify design before proceeding"
        ]
      },
      {
        "step": 5,
        "name": "cjk_specific_scan_if_applicable",
        "trigger": "content_contains_cjk",
        "actions": [
          "validate letter-spacing in cjk range",
          "validate line-height ≥ 1.7 for body",
          "validate weight pair in [100/200, 400/500]",
          "validate 0.125em breathing space at script boundaries",
          "trigger size_compensation rule for mixed-script same-line"
        ]
      },
      {
        "step": 6,
        "name": "checklist_verification",
        "actions": [
          "run all checklist items",
          "any fail → return to step 1"
        ]
      },
      {
        "step": 7,
        "name": "ai_slop_self_check",
        "_v0_4_mandatory": true,
        "actions": [
          "run section 6.3.5 Anti-AI-Slop checklist 8 items",
          "primary font not in section 4.4 blacklist",
          "no purple-pink-blue gradients",
          "no emoji decorations",
          "no filler verbs (Elevate/Unleash/Seamless)",
          "data is real or marked as placeholder",
          "placeholders follow section 11.4 standardized levels",
          "no centered hero",
          "cards not uniform same-size grid"
        ]
      }
    ],
    "enforcement": "skipping_pre_check_means_not_compliant"
  },

  "font_selection": {
    "_v0_4_mandatory": true,
    "_purpose": "Take a stance on fonts. Wrong font = AI fingerprint.",
    "latin_blacklist_production": [
      "Inter",
      "Roboto",
      "Helvetica",
      "Helvetica Neue",
      "Arial",
      "Open Sans",
      "Fraunces",
      "Space Grotesk"
    ],
    "latin_whitelist_by_context": {
      "default_modern": "{FILL_1_OR_2_FONTS_FROM_GEIST_SOHNE_GT_AMERICA}",
      "fashion_editorial": "{FILL_FONTS}",
      "premium_luxury": "{FILL_FONTS_FROM_CABINET_GROTESK_SATOSHI_ROOBERT}",
      "editorial_serif": "{FILL_FONTS_FROM_LYON_TEXT_NEWSREADER_INSTRUMENT_SERIF}",
      "data_technical_monospace": "{FILL_FONTS_FROM_GEIST_MONO_JETBRAINS_MONO_IBM_PLEX_MONO}"
    },
    "cjk_whitelist": [
      "PingFang SC",
      "Source Han Sans CN",
      "Noto Sans CJK SC",
      "Yu Gothic",
      "Hiragino Kaku Gothic ProN"
    ],
    "cjk_avoid": ["Microsoft YaHei", "SimSun/SimHei system defaults"],
    "sandbox_relaxation": {
      "permitted_fallback": "system-ui, -apple-system, BlinkMacSystemFont",
      "annotation_required": "spec or code header must explicitly state production replacement font"
    }
  },

  "modern_css": {
    "_v0_4_mandatory": true,
    "_purpose": "oklch primary color, color-mix interaction states, text-wrap balance/pretty, hanging-punctuation, tabular-nums",

    "color_expression": {
      "primary_format": "oklch",
      "fallback_format": "hex",
      "browser_support": "Chrome 111+, Safari 15.4+, Firefox 113+",
      "_dna_specific_oklch_tokens": "{FILL_PER_DNA — provide oklch equivalents for all subsystem hex tokens}"
    },

    "interaction_state_derivation": {
      "rule": "use color-mix() not hardcoded hex variants",
      "ratios": {
        "hover_dark_subsystems": "accent 85% + black 15%",
        "hover_light_subsystems": "accent 85% + white 15%",
        "active": "accent 75% + black 25%",
        "disabled": "accent 30% + bg_primary 70%",
        "accent_secondary_brand_spectrum": "accent_main 70% + bg_primary 30%"
      },
      "forbidden": "hardcoding new hex per state"
    },

    "mandated_text_rules": {
      "text_wrap_balance": {
        "applies_to": ["h1", "h2", "h3", ".hero"],
        "css": "text-wrap: balance;"
      },
      "text_wrap_pretty": {
        "applies_to": ["p", ".body", ".caption"],
        "css": "text-wrap: pretty;"
      },
      "text_spacing_trim": {
        "applies_to": ["*"],
        "css": "text-spacing-trim: space-all;"
      },
      "hanging_punctuation": {
        "applies_to": ["p", ".cjk-body"],
        "css": "hanging-punctuation: first;"
      }
    },

    "mandated_opentype_features": {
      "body_default": "font-feature-settings: 'kern', 'liga', 'calt';",
      "data_and_dashboards": "font-variant-numeric: tabular-nums;",
      "data_rule": "all numeric content in info moments must be tabular-nums"
    }
  },

  "style_locked": {
    "font_family_count": 1,
    "_font_family_candidates_latin_to_fill": ["{FONT_1}", "{FONT_2}"],
    "font_weight_pair": {
      "latin": { "light_axis": [200, 300], "bold_axis": [500, 600] },
      "cjk": { "light_axis": [100, 200], "bold_axis": [400, 500] }
    },
    "font_weight_forbidden": {
      "latin": [400, 700, 800, 900],
      "cjk": [300, 600, 700, 800, 900]
    },
    "letter_spacing": {
      "hero_latin_max_em": -0.02,
      "hero_cjk_em_range": [-0.08, -0.05],
      "caption_latin_min_em": 0.16,
      "caption_cjk_em_range": [0.10, 0.15]
    },
    "border_width_only_px": 0.5,
    "corner_radius": {
      "stage_max_px": "{0_or_other_per_DNA}",
      "info_max_px": "{4_or_other_per_DNA}"
    },
    "ratios": {
      "_critical_these_define_DNA_identity": "Style Relatives are the soul. Lock these carefully.",
      "h1_to_body_min_stage": "{NUMBER ≥ 3.0}",
      "h1_to_body_min_info": "{NUMBER ≥ 2.5}",
      "stage_whitespace_ratio_min": "{0.5_to_0.75}",
      "{DNA_SPECIFIC_RATIO}": "{VALUE}"
    },
    "accent": {
      "max_concurrent_default": 1,
      "max_concurrent_with_layered_modifier": 2,
      "signature_pages_can_exempt_accent_count": true
    }
  },

  "layout_safety": {
    "char_width_estimates_px": {
      "latin_geometric_sans_at_minus_0_02_em": {
        "size_14": 7,
        "size_84_hero": 38,
        "size_140_big_hero": 62
      },
      "cjk_block_glyph_at_minus_0_05_em": {
        "size_14": 14,
        "size_84_hero": 80,
        "size_140_big_hero": 134
      },
      "digits_punctuation": {
        "size_14": 5,
        "size_84_hero": 26,
        "size_140_big_hero": 44
      },
      "latin_uppercase_tracked_0_16_em": {
        "size_11": 9
      }
    },
    "vertical_fit_overflow_handling": {
      "fallback_order": [
        "reduce_hero_one_step",
        "reduce_caption_to_12px_floor",
        "reduce_paddings_to_75_percent",
        "truncate_text_content_never_clip_elements"
      ]
    },
    "auto_fail_states": [
      "text_bleeds_container_edge",
      "text_elements_overlap_more_than_2px",
      "hairline_rule_collapses_below_16px_width",
      "caption_exceeds_mode_char_limit",
      "cell_content_clipped_by_overflow_hidden"
    ]
  },

  "cjk_typography": {
    "_include_only_if_cjk_in_scope": true,
    "punctuation_rules": {
      "line_start_forbidden_chars": ["。", "、", ",", ")", "」", "』", "】", "!", "?", ":", ";"],
      "line_end_forbidden_chars": ["(", "「", "『", "【"]
    },
    "mixed_script": {
      "latin_cjk_breathing_space_em": 0.125,
      "latin_baseline_offset_vs_cjk_px": -1
    },
    "size_compensation_rules": {
      "ratios_latin_to_cjk": {
        "hero_same_line": [0.85, 0.92],
        "body_same_line": [0.92, 0.95],
        "caption_same_line": [0.95, 1.0]
      },
      "additional_rules": [
        "latin_baseline_offset_minus_1_to_minus_2_px_in_mixed_lines",
        "0_125em_breathing_space_still_required",
        "deliberate_imbalance_signatures_exempt_from_this_rule"
      ]
    },
    "anti_patterns": [
      "cjk_using_latin_letter_spacing",
      "cjk_using_weights_300_or_600",
      "mixed_script_no_breathing_space",
      "line_start_with_forbidden_char",
      "cjk_body_line_height_below_1_7",
      "mixed_script_same_line_no_size_compensation"
    ]
  },

  "modes": {
    "_describe_each_mode_per_DNA": "Aperture has stage + info; your DNA may have different mode structure",
    "{MODE_1_NAME}": {
      "required_elements": ["{ELEMENT_LIST}"],
      "{KEY_RULES}": "{VALUES}"
    },
    "{MODE_2_NAME}": {
      "required_elements": ["{ELEMENT_LIST}"],
      "{KEY_RULES}": "{VALUES}"
    }
  },

  "transitions_between_modes": {
    "allowed": ["{TRANSITION_TYPES}"],
    "forbidden": ["{BANNED_TRANSITIONS}"]
  },

  "subsystems": {
    "{DEFAULT_SUBSYSTEM_NAME}": {
      "is_default": true,
      "tokens": {
        "bg_primary": "{HEX}",
        "bg_secondary": "{HEX}",
        "text_primary": "{HEX}",
        "text_secondary": "{HEX}",
        "accent": "{HEX_OR_SLOT}",
        "border": "{HEX}"
      }
    },
    "_pattern_examples": [
      "atmospheric_swap (replace base color, keep structure)",
      "value_inversion (full token set inverted, eg light_paper)",
      "saturated_canvas (full-bleed brand color for chapters)",
      "extended_palette (add 3-5 muted colors for charts)",
      "layered_modifier (overlay accent layer by domain, eg brand_spectrum)",
      "complete_subsystem (entire token replacement, eg japanese_editorial)"
    ]
  },

  "media_patterns": {
    "patterns": {
      "A_full_bleed_hero": {
        "overlay_required": true,
        "overlay_opacity": 0.20,
        "applicable_modes": ["stage_or_equivalent"]
      },
      "B_bento_cell": {
        "corner_radius_max_px": 4,
        "max_brightness_ratio": 0.7,
        "applicable_modes": ["info_or_equivalent"]
      },
      "C_side_by_side": {
        "ratios_allowed": ["1:1.4", "1:1.7", "1:2"],
        "ratios_forbidden": ["1:1"],
        "gap_px_range": [8, 16]
      },
      "D_pictogram": {
        "size_px_range": [50, 80],
        "style": "fill_only_no_stroke",
        "color_constraint": "single_color_accent_or_text_primary"
      },
      "E_ambient_video": {
        "max_duration_seconds": 8,
        "audio": "muted",
        "max_pixel_change_percent": 5
      }
    },

    "placeholder_schema": {
      "html_attributes_required": [
        "data-aperture-media",
        "data-aspect",
        "data-pattern",
        "data-subsystem",
        "data-placeholder-level"
      ],
      "prompt_required_fields": [
        "ASPECT", "PATTERN", "SUBSYSTEM", "SUBJECT", "COMPOSITION",
        "MOOD", "PALETTE", "STYLE-TAGS", "FORBIDDEN", "MEDIUM"
      ],
      "aspect_ratios_allowed": ["16:9", "1:1", "3:4", "9:16", "4:5", "21:9"],
      "visual_levels": {
        "level_1_solid": { "spec": "bg_secondary + 0.5px accent border" },
        "level_2_hairline_pattern": { "spec": "45deg hairline pattern + 0.5px accent border" },
        "level_3_centered_tag": { "spec": "level_2 + center tag box with 3 lines" },
        "level_4_full_spec_card": { "spec": "level_3 + visible <details> with full prompt" }
      },
      "default_level_per_pattern": {
        "A_full_bleed_hero": "level_3",
        "B_bento_cell": "level_2",
        "C_side_by_side": "level_2",
        "D_pictogram": "level_2",
        "E_ambient_video": "level_3"
      }
    },

    "image_count_rules": {
      "max_photos_or_videos_per_moment": 3,
      "pictograms_not_counted_toward_photo_video_limit": true,
      "max_pictograms_per_moment": 6,
      "max_total_when_mixing": 8
    }
  },

  "signatures": {
    "_meta_rules": {
      "purpose": "deliberate breaks-from-norm that elevate DNA from 80% to 90%+",
      "max_per_page": 1,
      "max_percentage_per_deck_or_site": 0.30,
      "adjacent_pages_cannot_use_same_type": true,
      "must_have_content_reason": true,
      "exemption_scope": "signature_pages_can_exempt_section_4_constraints_but_not_section_3_universal_floor_or_pre_check"
    },

    "active": {
      "signature_{N}_{NAME}": {
        "spirit": "{ONE_SENTENCE}",
        "best_moment": "{WHERE_IN_DECK_OR_SITE}",
        "implementation": {
          "{SIZE_RULES}": "{VALUES}",
          "{POSITION_RULES}": "{VALUES}",
          "{COLOR_RULES}": "{VALUES}"
        },
        "content_requirements": "{WHAT_CONTENT_SUPPORTS_THIS}",
        "cjk_advantage": "{LOW | MEDIUM | HIGH | EXTREMELY_HIGH}",
        "forbidden": ["{WHAT_BREAKS_IT}"],
        "frequency": { "per_deck_max": 1 },
        "mutual_exclusion_adjacent": []
      }
    },

    "experimental": {
      "_status": "placeholders only, may activate in v0.4+ based on real usage",
      "_examples": [
        "punctuation_as_subject",
        "edge_bleed_number",
        "asymmetric_number_pair",
        "negative_space_logo",
        "the_misalignment"
      ]
    }
  },

  "anti_patterns": {
    "ugly_violations": [
      "three_or_more_weights_in_one_hierarchy",
      "title_and_body_same_weight",
      "five_or_more_font_sizes_per_screen",
      "pure_black_on_pure_white",
      "shadow_blur_gt_element_width",
      "more_than_three_alignment_columns"
    ],
    "drift_violations": [
      "{DNA_SPECIFIC_DRIFT_1}",
      "{DNA_SPECIFIC_DRIFT_2}",
      "{DNA_SPECIFIC_DRIFT_3}"
    ],
    "layout_violations": [
      "text_overflow",
      "text_overlap",
      "content_clipped_by_overflow_hidden",
      "hairline_collapsed_below_16px"
    ]
  },

  "ai_slop_anti_patterns": {
    "_v0_4_mandatory": true,
    "_purpose": "Third anti-pattern layer. Prevents AI-fingerprint outputs even when other rules pass.",

    "visual_traps": [
      "purple_pink_blue_full_screen_gradient",
      "rounded_card_with_left_border_accent_color",
      "pure_black_000000_background",
      "neon_outer_glow_text_shadow",
      "ai_purple_blue_palette_lila_ban",
      "emoji_decorating_titles",
      "ai_handdrawn_svg_illustrations_inline",
      "aggressive_bento_grid_as_default_layout",
      "hero_three_col_features_testimonials_cta_template",
      "uniform_equal_size_cards_grid",
      "centered_hero_h1",
      "circular_loading_spinner"
    ],

    "typography_traps": ["see_font_selection_latin_blacklist_production"],

    "content_traps": {
      "data_slop_examples_forbidden": [
        "10000_plus_happy_customers",
        "99_9_percent_uptime",
        "trusted_by_fortune_500"
      ],
      "filler_verbs_forbidden": ["Elevate", "Unleash", "Transform", "Revolutionize", "Empower", "Disrupt"],
      "filler_adjectives_forbidden": ["Seamless", "Next-gen", "Cutting-edge", "World-class", "Best-in-class"],
      "generic_names_forbidden": ["John Doe", "Acme Corp", "Lorem ipsum"],
      "rule": "if_2_or_more_filler_terms_present_section_6_3_auto_fail",
      "preferred_writing_style": "concrete_nouns_verifiable_numbers_real_verbs"
    },

    "layout_traps": [
      "three_col_equal_width_feature_cards",
      "every_section_same_layout_formula",
      "hero_features_pricing_testimonials_footer_template",
      "lorem_ipsum_in_placeholders"
    ],

    "auto_fail_quick_checklist": [
      "primary_font_in_blacklist",
      "purple_pink_blue_gradient_present",
      "emoji_decoration_present",
      "filler_verbs_or_adjectives_2_or_more",
      "fake_data_not_marked_as_placeholder",
      "lorem_ipsum_present",
      "centered_hero_present",
      "uniform_card_grid_present"
    ]
  },

  "variance_dial": {
    "_v0_4_mandatory": true,
    "_purpose": "Same locked DNA flexes from Editorial (1) to Audacious (3). Project-level decision.",

    "levels": {
      "1_editorial": {
        "intent": "serious reports, white papers, conservative SaaS",
        "stage_whitespace_min": 0.70,
        "info_whitespace_min": 0.50,
        "signature_frequency_max_percent": 0.10,
        "accent_saturation_max": 0.20,
        "color_block_count_max_per_deck": 0,
        "hero_to_body_ratio_range": "{FILL_RANGE_FOR_DIAL_1}",
        "recommended_signatures": ["{FILL_BASED_ON_DNA_SIGNATURES}"]
      },
      "2_default": {
        "intent": "B2B products, content PPT, brand sites",
        "stage_whitespace_min": 0.60,
        "info_whitespace_min": 0.40,
        "signature_frequency_max_percent": 0.30,
        "accent_saturation_max": 0.30,
        "color_block_count_max_per_deck": 3,
        "hero_to_body_ratio_range": "{FILL_RANGE_FOR_DIAL_2}",
        "recommended_signatures": ["all_active_signatures"]
      },
      "3_audacious": {
        "intent": "brand manifesto, art projects, concept launches",
        "stage_whitespace_min": 0.55,
        "info_whitespace_min": 0.35,
        "signature_frequency_max_percent": 0.50,
        "accent_saturation_max": 0.50,
        "color_block_count_max_per_deck": 5,
        "hero_to_body_ratio_range": "{FILL_RANGE_FOR_DIAL_3}",
        "recommended_signatures": ["all_active_plus_one_experimental"]
      }
    },

    "invariants_across_dials": [
      "section_3_universal_floor",
      "section_4_style_dna_locked_identity",
      "section_6_3_ai_slop_anti_patterns",
      "section_4_4_font_blacklist_whitelist",
      "section_10_cjk_typography",
      "section_3_5_pre_check_protocol_7_steps"
    ],

    "project_default_dial_mapping": {
      "{PROJECT_TYPE_1}": "{DIAL_1_2_OR_3}",
      "{PROJECT_TYPE_2}": "{DIAL_1_2_OR_3}"
    },

    "consistency_rule": {
      "principle": "dial_is_project_level_not_page_level",
      "forbidden": "switching_dial_mid_deck"
    },

    "pre_check_integration": {
      "step_1_addition": "declare variance_dial level on first artifact for project; subsequent artifacts inherit"
    }
  },

  "cross_medium": {
    "web_desktop": {
      "min_viewport_px": 1280,
      "{ADJUSTMENTS}": "{VALUES}"
    },
    "ppt_keynote": {
      "aspect_ratio": "16:9",
      "min_font_size_px_projection": 14,
      "rules": [
        "all_small_text_must_be_ge_14px_for_projection_legibility"
      ],
      "slide_vs_speaker_notes_rules": {
        "_v0_4_mandatory": true,
        "slide_visible_layer_must_contain": [
          "exactly_one_information_focus",
          "necessary_chart_or_visual",
          "section_marker_and_page_number"
        ],
        "slide_visible_layer_forbidden": [
          "more_than_4_bullet_points",
          "detailed_explanations_examples_quotes",
          "complete_paragraphs"
        ],
        "speaker_notes_must_contain": [
          "talking_points_3_to_5_per_slide",
          "transition_sentence_to_next_slide",
          "backup_data_for_likely_questions",
          "optional_asides"
        ],
        "five_second_test": {
          "fail_too_complex": "≥ 5 seconds to grasp main message → simplify",
          "fail_too_thin": "≤ 1 second instant grasp → too sparse",
          "pass_window": "2_to_4_seconds"
        }
      }
    },
    "mobile": {
      "max_viewport_px": 480,
      "section_marker_degrade": "brand_meta_with_16px_gap_no_hairline"
    }
  },

  "checklist": [
    "pre_check_7_steps_completed_v0_4_includes_ai_slop_scan",
    "section_marker_or_DNA_signature_element_present",
    "two_weight_groups_only_correct_for_language",
