  "cross_medium": {
    "web_desktop": {
      "min_viewport_px": 1280,
      "stage_hero_px_range": [84, 96],
      "info_bento_gap_px": 8
    },
    "ppt_keynote": {
      "aspect_ratio": "16:9",
      "stage_hero_px_range": [96, 140],
      "min_font_size_px_projection": 14,
      "_v0_3_fix": "v0.2 lacked projection min font size, causing 9px legends in playtest",
      "rules": [
        "all_small_text_must_be_ge_14px_for_projection_legibility",
        "chapter_pages_must_use_color_block_subsystem",
        "data_pages_must_use_data_palette_subsystem"
      ],
      "slide_vs_speaker_notes_rules": {
        "_v0_4_added": true,
        "slide_visible_layer_must_contain": [
          "exactly_one_information_focus",
          "necessary_chart_or_visual",
          "section_marker_and_page_number"
        ],
        "slide_visible_layer_forbidden": [
          "more_than_4_bullet_points",
          "detailed_explanations_examples_quotes",
          "complete_paragraphs"
        ],
        "speaker_notes_must_contain": [
          "talking_points_3_to_5_per_slide_not_reading_screen",
          "transition_sentence_to_next_slide",
          "backup_data_supporting_details_for_likely_questions",
          "optional_asides_relevant_stories_industry_context"
        ],
        "five_second_test": {
          "rule": "after_designing_glance_5_seconds",
          "fail_too_complex": "≥ 5 seconds to grasp main message → simplify to one hero",
          "fail_too_thin": "≤ 1 second instant grasp → too sparse, add caption or data",
          "pass_window": "2_to_4_seconds"
        }
      },
      "slide_deck_skeleton": {
        "_v0_5_added": true,
        "_purpose": "v0.4 playtest: JS transform:scale() + fixed 1920×1080 px caused viewport mismatch in Claude artifacts. CSS-only skeleton now mandatory.",
        "forbidden": ["JS_fitStage_transform_scale", "fixed_1920x1080_px_dimensions", "translateY_manual_pagination"],
        "required_approach": {
          "viewport_fit": "CSS aspect-ratio:16/9 + container-type:inline-size + cqi units",
          "pagination": "scroll-snap-type:y mandatory on wrapper, scroll-snap-align:start on each slide",
          "internal_sizing": "all dimensions in cqi (1cqi = 1% of container inline-size), no fixed px"
        },
        "see_recipes": "aperture-recipes.md §R1"
      }
    },
    "mobile": {
      "max_viewport_px": 480,
      "h1_to_body_ratio_min_relaxed": 3.5,
      "bento_layout": "single_column_stack",
      "min_whitespace_ratio_relaxed": 0.4,
      "min_font_size_px_relaxed": 12,
      "section_marker_degrade": "brand_meta_with_16px_gap_no_hairline"
    }
  },

