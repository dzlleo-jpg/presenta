        "scale_policy": { "hero": "medium-with-rotation", "supporting": "small-scattered" },
        "allowed_rotation_deg": 5,
        "type_image_relation": "integration",
        "integration_requirements": {
          "accent_type": "handwritten-script",
          "overlay": "none (text placed in image margin whitespace)"
        },
        "prompt_template": "warm earth-tone moodboard collection: ceramic object, linen texture, model silhouette, all in unified cream-sage-rust palette, film grain, analog warmth"
