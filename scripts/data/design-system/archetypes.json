  "archetype_selection_decision_tree": {
    "data-heavy + B2B/investor": ["editorial-swiss", "tech-dark-mode"],
    "brand launch + story-led": ["magazine-big-type", "luxury-editorial"],
    "luxury/craft/architecture": ["minimal-architectural", "luxury-editorial"],
    "creative/fashion/portfolio": ["moodboard-collage", "magazine-big-type"],
    "AI/developer/fintech": ["tech-dark-mode", "editorial-swiss"],
    "philosophy/research/concept": ["minimal-architectural", "tech-dark-mode"]
  }
