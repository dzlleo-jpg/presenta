    "tech-dark-mode": {
      "name": "Tech Dark Mode",
      "pick_when": ["AI products", "developer tools", "fintech", "deep tech", "crypto"],
      "signature_move": "Black canvas + electric accent + mono data",
      "tonality_keywords": ["precise", "futuristic", "confident", "systems-thinking"],

      "color": {
        "neutral": {
          "bg": "#0E1013",
          "surface": "#1A1D22",
