      "imagery_script": {
        "primary_language": "product-still-life",
        "secondary_language": "editorial-portrait",
        "tonal_treatment": "grain-overlay",
        "grain_intensity": "medium",
        "unified_palette_wash": "warm earth tones (cream, sage, rust, ochre)",
        "aspect_ratios": ["1:1", "4:5", "3:4"],
        "role_ratio_map": { "product": "1:1", "portrait": "4:5", "texture": "3:4" },
