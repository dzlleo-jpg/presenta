        "aspect_ratios": ["16:9", "21:9", "1:1"],
        "role_ratio_map": { "hero": "21:9", "supporting": "1:1" },
        "coverage_target": "60-70%",
        "scale_policy": { "hero": "full-bleed", "supporting": "ultra-small-with-wide-margin" },
        "rhythm": "one large image per page, minimal text",
        "type_image_relation": "separation",
        "prompt_template": "minimal architectural photography, single building, overcast sky, desaturated, geometric, no people, 35mm Fujifilm look, wide composition"
      }
    },

    "moodboard-collage": {
      "name": "Moodboard Collage",
