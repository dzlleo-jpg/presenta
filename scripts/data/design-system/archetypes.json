{
  "$schema_version": "1.2.0",
  "description": "Six production-ready style archetypes built on the Meridian Design System. Each archetype is a pre-validated bundle of Layer A values that automatically satisfies Layer B DNA when applied.",

  "archetypes": {

    "editorial-swiss": {
      "name": "Editorial Swiss",
      "pick_when": ["investor decks", "B2B SaaS", "consulting", "financial reports", "data-heavy narratives"],
      "signature_move": "Giant numbers + geometric headline + hairline rules",
      "tonality_keywords": ["precise", "authoritative", "restrained", "credible", "editorial"],

      "color": {
        "neutral": {
          "bg": "#F5F4F0",
          "surface": "#FAF9F6",
          "text": "#0E1013",
          "text_muted": "#5A6069",
          "hairline": "#D8DADC"
        },
        "accent": { "primary": "#0E1013", "secondary": "#C9FF3B" },
        "temperature": "cool",
        "mode": "light",
        "variants": {
          "dark_version": {
            "bg": "#0E1013",
            "text": "#F5F4F0",
            "accent": "#C9FF3B"
          }
        }
      },

      "typography": {
        "families": {
          "heading": {
            "stack": "'Archivo', 'Noto Serif SC', 'PingFang SC', 'Songti SC', system-ui, sans-serif",
            "category": "geometric-grotesk"
          },
          "body": {
            "stack": "'Inter Tight', 'Noto Sans SC', 'PingFang SC', 'Hiragino Sans GB', system-ui, sans-serif",
            "category": "utilitarian-sans"
          },
          "mono": {
            "stack": "'IBM Plex Mono', 'Noto Sans SC', ui-monospace, monospace"
          }
        },
        "scale": {
          "display": { "size_px": 112, "weight": 300, "line_height": 0.95, "tracking": -0.035 },
          "h1":      { "size_px": 88,  "weight": 300, "line_height": 0.95, "tracking": -0.035 },
          "h2":      { "size_px": 56,  "weight": 300, "line_height": 1.0, "tracking": -0.025 },
          "body":    { "size_px": 15,  "weight": 400, "line_height": 1.6, "tracking": 0 },
          "label":   { "size_px": 11,  "weight": 400, "line_height": 1.0, "tracking": 0.12, "uppercase": true }
        }
      },

      "grid": { "columns": 12, "gutter": 24, "margin": 48 },
      "radius": { "none": 0 },
      "shadow": "none",

      "accent_devices": ["giant-number", "page-label-header", "hairline-divider"],

      "imagery_script": {
        "primary_language": "architectural-photography",
        "secondary_language": "product-still-life",
        "tonal_treatment": "bw_or_duotone",
        "duotone_default": ["#0E1013", "#5A6069"],
        "aspect_ratios": ["16:9", "1:1"],
        "role_ratio_map": { "hero": "16:9", "supporting": "1:1" },
        "coverage_target": "35-45%",
        "scale_policy": { "hero": "full-bleed-one-side", "supporting": "ultra-small" },
        "rhythm": "every 3 pages at least 1 image",
        "type_image_relation": "separation",
        "prompt_template": "editorial B&W architectural photograph, single subject, negative space, natural light, high contrast, magazine-quality, Leica M composition"
      }
    },

    "magazine-big-type": {
      "name": "Magazine Big-Type",
      "pick_when": ["brand launches", "creative pitches", "cultural products", "manifesto decks"],
      "signature_move": "Display type cropping off canvas",
      "tonality_keywords": ["bold", "expressive", "cultural", "confident"],

      "color": {
        "neutral": {
          "bg": "#F5F4F0",
          "surface": "#ECEDEE",
          "text": "#0E1013",
          "text_muted": "#5A6069",
          "hairline": "#D8DADC"
        },
        "accent": { "primary": "#E5523C" },
        "temperature": "warm",
        "mode": "light"
      },

      "typography": {
        "families": {
          "heading": {
            "stack": "'Archivo', 'Noto Serif SC', 'PingFang SC', system-ui, sans-serif",
            "category": "geometric-grotesk"
          },
          "body": {
            "stack": "'Inter Tight', 'Noto Sans SC', 'PingFang SC', system-ui, sans-serif",
            "category": "utilitarian-sans"
          },
          "mono": {
            "stack": "'IBM Plex Mono', 'Noto Sans SC', ui-monospace, monospace"
          }
        },
        "scale": {
          "display": { "size_px": 160, "weight": 600, "line_height": 0.85, "tracking": -0.03 },
          "h1":      { "size_px": 88,  "weight": 500, "line_height": 0.95, "tracking": -0.03 },
          "h2":      { "size_px": 56,  "weight": 500, "line_height": 1.0, "tracking": -0.02 },
          "body":    { "size_px": 15,  "weight": 400, "line_height": 1.6, "tracking": 0 },
          "label":   { "size_px": 11,  "weight": 400, "line_height": 1.0, "tracking": 0.12, "uppercase": true }
        }
      },

      "grid": { "columns": 12, "gutter": 24, "margin": 48 },
      "radius": { "none": 0 },
      "shadow": "none",

      "accent_devices": ["oversized-caption", "page-label-header"],

      "imagery_script": {
        "primary_language": "editorial-portrait",
        "secondary_language": "product-still-life",
        "tonal_treatment": "warm-wash",
        "aspect_ratios": ["4:5", "16:9"],
        "role_ratio_map": { "portrait": "4:5", "product": "16:9" },
        "coverage_target": "50-60%",
        "scale_policy": { "hero": "full-bleed" },
        "type_image_relation": "integration",
        "integration_requirements": {
          "min_type_size_px": 120,
          "overlay": "gradient-40"
        },
        "prompt_template": "high-fashion editorial portrait, dramatic lighting, 4:5 composition, subject looking away, unified warm magazine tone, Kodak Portra film emulation"
      }
    },

    "minimal-architectural": {
