        "glow_color": "accent.primary",
        "aspect_ratios": ["16:9", "21:9"],
        "role_ratio_map": { "hero": "16:9", "atmospheric": "21:9" },
        "coverage_target": "40-50%",
        "scale_policy": { "hero": "full-bleed", "dataviz": "in-grid" },
        "type_image_relation": "separation",
