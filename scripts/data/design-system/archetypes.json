          "bg": "#F5F4F0",
          "surface": "#ECEDEE",
          "text": "#1A1D22",
          "text_muted": "#5A6069",
          "hairline": "#D8DADC"
        },
        "accent": { "primary": "#E5523C", "secondary": "#C9FF3B" },
